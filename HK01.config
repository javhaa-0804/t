 match ip address prefix-list NO-ROUTE
!
route-map OVH-IN permit 10 
 match rpki invalid
 set community 55805:666
!
route-map OVH-IN permit 20 
 match as-path 208
 set local-preference 755
 set community 55805:500 55805:501 55805:512
!
route-map MICROSOFT-IN permit 10 
 match rpki invalid
 set community 55805:666
!
route-map MICROSOFT-IN permit 20 
 match as-path 204
 set local-preference 760
 set community 55805:500 55805:501 55805:512
!
snmp-server community DurslenUzuulev RO SNMP-Access
snmp-server community N3tfl0w_Mobic0m RO SNMP-Access
snmp-server trap-source GigabitEthernet0
snmp-server location 16-T-01-00001
snmp-server contact peering@mobicom.mn /+976-75759944-9134/
mpls ldp router-id Loopback100 force
!
!
!
!
control-plane
!
!
!
!
!
banner motd ^C

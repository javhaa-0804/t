! Command: show running-config
! device: ISP-AGG1 (DCS-7504N, EOS-4.33.6M)
!
! boot system flash:/EOS64-4.33.6M.swi
!
no aaa root
!
username admin privilege 15 role network-admin secret sha512 $6$sZjXs2cE85Ei4uFy$Lkng/Wj08TMXwBuwRTmY3D2VtOluGfyxAfOUzNlcmFRglZ/OJ84s6Ob9.uqsUURDbIGCtJq7aWm4y4akAiABk0
!
hardware counter feature mpls lfib
hardware counter feature mpls tunnel
hardware counter feature subinterface out
hardware counter feature subinterface in
!
hardware access-list update default-result permit
!
no service interface inactive port-id allocation disabled
!
service routing protocols model multi-agent
!
logging console debugging
logging host 192.168.242.11
logging vrf mgmt host 192.168.242.105
logging vrf mgmt host 192.168.242.11
logging source-interface Management1/1
!
hostname ISP-AGG1
!
sflow sample 1000
sflow polling-interval 10
sflow destination 27.123.215.87
sflow source-interface Loopback0
sflow vrf mgmt destination 192.168.242.105
sflow vrf mgmt source-interface Management1/1
sflow extension bgp
sflow run
!
no sflow hardware acceleration
!
snmp-server ipv4 access-list SSH vrf MGMT
snmp-server ipv4 access-list SSH vrf mgmt
snmp-server location 16-T-15-00105
snmp-server vrf mgmt local-interface Management1/1
snmp-server community DurslenUzuulev ro
snmp-server community Mongolmaa ro SSH
snmp-server community N3tfl0w_Mobic0m ro benocs
snmp-server host 192.168.242.11 vrf mgmt version 2c DurslenUzuulev udp-port 161
snmp-server host 192.168.242.11 vrf mgmt version 2c Mongolmaa udp-port 161
snmp-server host 192.168.242.20 vrf mgmt version 2c Mongolmaa udp-port 161
snmp-server host 192.168.242.31 vrf mgmt version 2c DurslenUzuulev udp-port 161
snmp-server vrf mgmt
!
spanning-tree mode mstp
!
service unsupported-transceiver OriginalForce f52ab166
!
system l1
   unsupported speed action error
   unsupported error-correction action error
!
clock timezone Hongkong
!
vrf instance MGMT
!
vrf instance mgmt
!
tacacs-server host 192.168.242.17 vrf mgmt key 7 1063375F2B16130A4836
!
aaa group server tacacs+ TacServer
   server 192.168.242.17 vrf mgmt
!
aaa authentication login default group TacServer local
aaa authentication login console group TacServer local
aaa authentication policy on-success log
aaa authentication policy on-failure log
aaa authorization serial-console
aaa authorization exec default group TacServer local
aaa authorization commands all default group TacServer local
aaa accounting exec console start-stop group TacServer
aaa accounting exec default start-stop group TacServer
aaa accounting commands all default start-stop group TacServer
!

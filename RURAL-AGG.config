! Command: show running-config
! device: RURAL-AGG1 (DCS-7280SR3-48YC8, EOS-4.33.6M)
!
! boot system flash:/EOS64-4.33.6M.swi
!
no aaa root
!
username mobicom privilege 15 secret sha512 $6$fxtIqnv9eFXhnYi6$3V1lyTygTkp.KPDigUeKPDicITCOmVPmf5tyrcuKmAzF99fHkodEhAMG67ciZeMWWPkiFDOHnplZQZdrmrZ3I0
!
hardware counter feature subinterface out
hardware counter feature subinterface in
!
no service interface inactive port-id allocation disabled
!
service routing protocols model multi-agent
!
logging buffered 65000
logging vrf MGMT host 192.168.242.11
!
hostname RURAL-AGG1
!
sflow sample 1000
sflow polling-interval 10
sflow vrf MGMT destination 192.168.242.105 2055
sflow vrf MGMT source-interface Management1
sflow destination 192.168.242.105 2055
sflow source-interface Loopback0
sflow extension bgp
sflow run
!
no sflow hardware acceleration
!
snmp-server ipv4 access-list SSH vrf MGMT
snmp-server location 16-T-15-00105
snmp-server vrf MGMT local-interface Management1
snmp-server community 5n#^Tsag!rag ro SSH
snmp-server host 192.168.242.105 vrf MGMT version 2c 5n#^Tsag!rag udp-port 161
snmp-server host 192.168.242.11 vrf MGMT version 2c 5n#^Tsag!rag udp-port 161
snmp-server host 192.168.242.11 vrf mgmt version 2c 5n#^Tsag!rag udp-port 161
snmp-server host 192.168.242.20 vrf MGMT version 2c 5n#^Tsag!rag udp-port 161
snmp-server host 192.168.242.31 vrf MGMT version 2c 5n#^Tsag!rag udp-port 161
snmp-server host 192.168.242.31 vrf mgmt version 2c 5n#^Tsag!rag udp-port 161
snmp-server vrf MGMT
!
spanning-tree mode mstp
!
service unsupported-transceiver OriginalForce f52ab166
!
system l1
   unsupported speed action error
   unsupported error-correction action error
!
clock timezone Hongkong
!
vlan 2999
!
vrf instance MGMT
!
tacacs-server host 192.168.242.17 vrf MGMT key 7 052638490F4D4F085D37
!
aaa group server tacacs+ TacServer
   server 192.168.242.17 vrf MGMT
!
aaa authentication login default group TacServer local
aaa authentication login console group TacServer local
aaa authentication policy on-success log
aaa authentication policy on-failure log
aaa authorization serial-console
aaa authorization exec default group TacServer local
aaa authorization commands all default group TacServer local
aaa accounting exec console start-stop group TacServer
aaa accounting exec default start-stop group TacServer
aaa accounting commands all default start-stop group TacServer
!

interface Management1
   vrf MGMT
   ip address 10.44.1.3/24
!
ip access-list SNMP-Access
   15 permit ip 192.168.242.0/24 any
   90 deny ip any any
!
ip access-list standard SSH
   10 permit 192.168.244.0/24
   20 permit 192.168.242.0/24
   30 permit 10.8.90.0/24
   40 permit 10.44.1.0/24
   50 permit 10.8.88.0/24
!
ip routing
no ip routing vrf MGMT
!
ipv6 unicast-routing
!
ip route 192.168.242.0/24 10.8.90.1
ip route 192.168.244.0/24 10.8.90.1
ip route vrf MGMT 0.0.0.0/0 10.44.1.254
!
mpls ip
!
ip ftp client source-interface Management1
!
ntp server 10.8.90.1
ntp server 10.8.90.2 prefer
!
patch panel
   patch BAH_Protection
      connector 1 interface Port-Channel4.2244
      connector 2 interface Ethernet48.2244
   !
   patch BAU_Protection
      connector 1 interface Port-Channel7.2342
      connector 2 interface Ethernet48.2342
   !
   patch DOR-PTN-PROTECTION
      connector 2 interface Ethernet48.90
!
router isis RURAL-SR
   hello padding disabled
   net 49.0001.0100.0809.0201.00
   is-hostname RURAL_AGG1
   router-id ipv4 10.8.90.201
   log-adjacency-changes
   timers local-convergence-delay protected-prefixes
   !
   address-family ipv4 unicast
      bfd all-interfaces
      fast-reroute ti-lfa mode link-protection
   !
   segment-routing mpls
      no shutdown
!
router multicast
   ipv4
      software-forwarding kernel
   !
   ipv6
      software-forwarding kernel
!
ip tacacs vrf mgmt source-interface Management1
!
management ssh
   ip access-group SSH in
!
end
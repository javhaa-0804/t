route-map 3G-CONNECTED permit 10
   match ip address prefix-list 3G-CONNECTED
   set local-preference 200
!
route-map LTE-CONNECTED permit 10
   match ip address prefix-list LTE-CONNECTED
   set local-preference 200
!
route-map TRX-MONITORING-CONNECTED permit 10
   match ip address prefix-list TRX-MONITORING-CONNECTED
!
route-map USMS-CONNECTED permit 10
   match ip address prefix-list USMS-CONNECTED
!
router bgp 65530
   router-id 10.150.33.1
   neighbor 10.8.90.1 remote-as 65530
   neighbor 10.8.90.1 next-hop-self
   neighbor 10.8.90.1 update-source Loopback0
   neighbor 10.8.90.1 description CORE1
   neighbor 10.8.90.1 send-community extended
   neighbor 10.8.90.2 remote-as 65530
   neighbor 10.8.90.2 next-hop-self
   neighbor 10.8.90.2 update-source Loopback0
   neighbor 10.8.90.2 description CORE2
   neighbor 10.8.90.2 send-community extended
   !
   address-family evpn
      neighbor default encapsulation mpls next-hop-self source-interface Loopback0
      neighbor 10.8.90.1 activate
      neighbor 10.8.90.2 activate
   !
   address-family ipv4
      neighbor 10.8.90.1 activate
      neighbor 10.8.90.2 activate
   !
   address-family vpn-ipv4
      neighbor 10.8.90.1 activate
      neighbor 10.8.90.2 activate
   !
   vrf IPN-MONITORING
      rd 10.44.1.1:300
      route-target import vpn-ipv4 10.44.1.1:300
      route-target export vpn-ipv4 10.44.1.1:300
      redistribute ospf
   !
   vrf MCN-INEG-VPN
      rd 65530:808
      route-target import vpn-ipv4 65530:888
      route-target export vpn-ipv4 65530:808
      redistribute connected route-map MCN-INEG
   !
   vrf MOBICOM-3G
      rd 65530:300
      route-target import vpn-ipv4 65530:3002
      route-target export vpn-ipv4 65530:3332
      redistribute connected route-map 3G-CONNECTED
   !
   vrf MOBICOM-LTE
      rd 65530:400
      route-target import vpn-ipv4 65530:444
      route-target export vpn-ipv4 65530:444
      redistribute connected route-map LTE-CONNECTED
   !
   vrf MOBICOM-USMS
      rd 65530:600
      route-target import vpn-ipv4 65530:6005
      route-target export vpn-ipv4 65530:6665
      redistribute connected route-map USMS-CONNECTED
   !
   vrf MOBINET-INTERNET
      rd 9484:100
      route-target import vpn-ipv4 9484:111
      route-target export vpn-ipv4 9484:111
      redistribute ospf
   !
   vrf TRX-MONITORING
      rd 65530:500
      route-target import vpn-ipv4 65530:5004
      route-target export vpn-ipv4 65530:5554
      redistribute connected route-map TRX-MONITORING-CONNECTED
   !
   vrf WICOM
      rd 10.91.1.254:9130
      route-target import vpn-ipv4 9484:555
      route-target export vpn-ipv4 9484:555
      redistribute ospf
!
router isis RURAL-SR
   hello padding disabled
   net 49.0001.0101.5003.3001.00
   is-hostname PE-ARKHANGAI
   router-id ipv4 10.150.33.1
   log-adjacency-changes
   timers local-convergence-delay protected-prefixes
   !
   address-family ipv4 unicast
      fast-reroute ti-lfa mode link-protection
   !
   segment-routing mpls
      no shutdown
!
router multicast
   ipv4
      software-forwarding kernel
   !
   ipv6
      software-forwarding kernel
!
router ospf 391 vrf WICOM
   router-id 10.90.33.253
   network 172.20.33.252/30 area 0.0.0.0
   max-lsa 12000
   default-information originate always
!
router ospf 457 vrf MOBINET-INTERNET
   router-id 10.4.33.253
   network 172.20.33.252/30 area 0.0.0.0
   max-lsa 12000
   default-information originate always
!
router ospf 1800 vrf IPN-MONITORING
   router-id 172.20.33.129
   network 172.20.33.128/30 area 0.0.0.0
   max-lsa 12000
   default-information originate always
!
ip tacacs vrf MGMT source-interface Management1
!
management ssh
   ip access-group VTY-Access in
!

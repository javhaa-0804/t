!<route-map>
route-map Default_Route_3G permit 10
  match ip address prefix-list Default_Route_3G
$
route-map Default_Route_LTE permit 10
  match ip address prefix-list Default_Route_LTE
$
route-map Default_Route_MW permit 10
  match ip address prefix-list Default_Route_MW
$
route-map Default_Route_USMS permit 10
  match ip address prefix-list Default_Route_USMS
$
route-map Khivs-TO-Cisco_3G permit 10
  match ip address prefix-list Khivs-TO-Cisco_3G
$
route-map Khivs-TO-Cisco_LTE permit 10
  match ip address prefix-list Khivs-TO-Cisco_LTE
$
route-map Khivs-TO-Cisco_MW permit 10
  match ip address prefix-list Khivs-TO-Cisco_MW
$
route-map Khivs-TO-Cisco_USMS permit 10
  match ip address prefix-list Khivs-TO-Cisco_USMS
$
route-map SET-LABEL permit 10
  set mpls-label
$
!</route-map>
!<system-user>
system-user
  account-switch on accounting-template 2002
  authorization-template 1
    bind aaa-authorization-template 2002
    local-privilege-level 7
  $
  authorization-template 2
    bind aaa-authorization-template 2001
    local-privilege-level 15
  $
  authorization-template 7
    bind aaa-authorization-template 2001
    local-privilege-level 7
  $
  authentication-template 1
    bind aaa-authentication-template 2002
  $
  authentication-template 2
    bind aaa-authentication-template 2001
  $
  login ascii authentication-template 1 authortication-template 1
  user-default
    bind authentication-template 1
    bind authorization-template 1
    enable-type aaa authentication-template 1
  $
  user-name mobicom
    bind authentication-template 2
    bind authorization-template 2
    password encrypted *21*Cd9FBNz0tjJfcP3wbYwsSG2MLEhtjCxIbYwsSDvChiV6ClA3vWw3t

!<mpls-te>
mpls traffic-eng
  cspf delay switch-over 60
  cspf preferred-igp isis
  router-id 10.8.90.18
  reoptimize timers delay installation-delay-time 300
  reoptimize timers frequency 3600
  unactive timer 30
  signalling graceful-restart
  signalling graceful-restart extend recovery-path
  signalling hello graceful-restart timers recovery-time 600000
  signalling hello graceful-restart timers restart-time 300000
  signalling node hello
  signalling retransmit
  signalling refresh reduction
  explicit-path name Bold_8EA&Khivs_8EA-TO-Access_Device
    index 1 exclude-address router-id 10.8.90.19
  $
  explicit-path name Khivs-TO-TCB1-1
    index 1 next-address strict 10.8.88.89
  $
  explicit-path name Khivs-TO-TCB1-2
    index 1 next-address strict 10.8.88.94
    index 2 next-address strict 10.8.88.98
    index 3 next-address strict 10.8.88.102
  $
  explicit-path name Khivs_8EA&TCB#1-1_18EA-TO-Access_Device
    index 1 exclude-address router-id 10.8.90.1
  $
  tunnel te_tunnel1
    tunnel destination ipv4 10.8.90.1
    tunnel mpls traffic-eng auto-reoptimize main-lsp
    tunnel mpls traffic-eng auto-reoptimize hsb-lsp
    tunnel mpls traffic-eng bfd interval 10 min-rx 10 multiplier 3
    tunnel mpls traffic-eng record-route
    tunnel mpls traffic-eng path-option 1 explicit-path name Khivs-TO-TCB1-1
    tunnel mpls traffic-eng path-option 2 dynamic
    tunnel mpls traffic-eng hot-standby protect 1 dynamic
    tunnel mpls traffic-eng hot-standby protect 2 dynamic prefer
  $
  tunnel te_tunnel2
    tunnel destination ipv4 10.8.90.2
    tunnel mpls traffic-eng auto-reoptimize main-lsp
    tunnel mpls traffic-eng auto-reoptimize hsb-lsp
    tunnel mpls traffic-eng bfd interval 10 min-rx 10 multiplier 3
    tunnel mpls traffic-eng record-route
    tunnel mpls traffic-eng path-option 1 explicit-path name Khivs-TO-TCB1-2
    tunnel mpls traffic-eng path-option 2 dynamic
    tunnel mpls traffic-eng hot-standby protect 1 dynamic
    tunnel mpls traffic-eng hot-standby protect 2 dynamic prefer
  $

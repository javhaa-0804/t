  tunnel preferring mpls-te te_tunnel1
  tunnel select-seq ldp-lsp te-lsp sr-be
$
tunnel-policy Khivs-TO-TCB1-2
  tunnel preferring mpls-te te_tunnel2
  tunnel select-seq ldp-lsp te-lsp sr-be
$
tunnel-policy TunnelPolicy-1
  tunnel selecting mpls-te te_tunnel1
$
tunnel-policy TunnelPolicy-2
  tunnel selecting mpls-te te_tunnel2
$
!</tunnel-policy>

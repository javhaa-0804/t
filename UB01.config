route-policy PASS
  pass
end-policy
!
route-policy DEFAULT
  if destination in (0.0.0.0/0) then
    pass
  endif
end-policy
!
route-policy ICNC-IN
  if validation-state is invalid then
    drop
  endif
  if as-path in MONGOLIAN-ISP then
    drop
  endif
  if destination in NON-RUSSIA then
    drop
  endif
  if community matches-any TTK-EURO then
    set local-preference 50
  endif
  if community matches-any RUSSIA then
    set local-preference 650
  endif
end-policy
!
route-policy UTRS-IN
  if destination in (0.0.0.0/0 eq 32) then
    set next-hop discard
    done
  endif
  drop
end-policy
!
route-policy ICNC-OUT
  if community matches-any FROM-ARBOR then
    set community TTK-BLACKHOLE
  endif
  if destination in TO-TTK-ICNC then
    set community PREPEND-TTK
  endif
end-policy
!
route-policy ISP-AGG1
  if destination in (0.0.0.0/0, 27.123.212.250/32) then
    pass
  endif
end-policy
!
route-policy ISP-AGG2
  if destination in (0.0.0.0/0, 27.123.212.250/32) then
    pass
  endif
end-policy
!
route-policy MSKIX-IN
  if validation-state is invalid then
    drop
  endif
  if destination in NON-MSKIX then
    set local-preference 50
  elseif apply SetLocalPref700 then
    set community (55805:500, 55805:502, 55805:522)
  endif
end-policy
!
route-policy NO-ROUTE
end-policy
!
route-policy UTRS-OUT
  if destination in (0.0.0.0/0 eq 32) and community matches-any (99:99) then
    set community (55805:0)
  endif
end-policy
!
route-policy ARBOR-OUT
  pass
end-policy
!
route-policy GEMNET-IN
  if validation-state is invalid then
    drop
  endif
  if destination in GEMNET-IN then
    set local-preference 800
  endif
end-policy
!
route-policy KENTIK_IN
end-policy
!
route-policy MSKIX-OUT
  if community matches-any (99:99) then
    set community (65535:666)
    set next-hop 195.208.208.6
  endif
  if community matches-any NO-IX-EURO-MSKIX then
    drop
  endif
  if community matches-any 1X-IX-EURO-MSKIX then
    prepend as-path 55805
  endif
  if community matches-any 2X-IX-EURO-MSKIX then
    prepend as-path 55805 2
  endif
  if community matches-any 3X-IX-EURO-MSKIX then
    prepend as-path 55805 3
  endif
  if community matches-any SUMMARY then
    pass
  endif
end-policy

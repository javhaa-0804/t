  if community matches-any 1X-GW-ASIA then
    prepend as-path 55805
  endif
  if community matches-any 2X-GW-ASIA then
    prepend as-path 55805 2
  endif
  if community matches-any 3X-GW-ASIA then
    prepend as-path 55805 3

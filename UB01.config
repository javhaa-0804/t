route-policy DIRECT-PEERING
  if as-path in MONGOLIAN-ISP then
    drop
  else
    set local-preference 700
  endif
end-policy
!
route-policy LUMEN-HSIP-OUT
  if community matches-any (99:99) then
    set community (3356:9999)
  endif
  if destination in (27.123.212.0/24, 27.123.214.0/24) then
    drop
  endif
  if community matches-any NO-GW-EURO-LUMEN then
    drop
  endif
  if community matches-any 1X-GW-EURO-LUMEN then
    prepend as-path 55805
  endif
  if community matches-any 2X-GW-EURO-LUMEN then
    prepend as-path 55805 2
  endif
  if community matches-any 3X-GW-EURO-LUMEN then
    prepend as-path 55805 3
  endif
  if community matches-any SUMMARY then
    set community LUMEN-PREPEND
  endif
end-policy
!
route-policy CT-MAINLAND-OUT
  #  if community matches-any NO-GW-ASIA then
  #    drop

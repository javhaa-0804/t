  if community matches-every (55805:200) then
    pass
  endif
end-policy
!
route-policy LUMEN-HSIP-IN
  if validation-state is invalid then
    drop
  endif
  if destination in NON-LUMEN then
    set local-preference 50
  elseif destination in LUMEN-HSIP then
    set local-preference 750
  elseif community matches-any LUMEN-RU-REGION then
    apply SetLocalPref700
    set community (55805:600, 55805:602, 55805:621)
  else
    set local-preference 50
  endif
end-policy
!
route-policy TO-GEMNET-OUT
  if destination in TO-GEMNET-OUT then
    pass
  endif
end-policy
!
route-policy CT-MAINLAND-IN
  if validation-state is invalid then
    drop
  endif
  if as-path in MONGOLIAN-ISP then
    drop
  endif
  apply SetLocalPref650
  set community (55805:601)
  if as-path in CHINA-MAINLAND then
    apply SetLocalPref750
    set community (55805:601)
  endif
end-policy

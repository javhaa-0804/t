!
router ospf IPN-MONITORING
 vrf IPN-MONITORING
  distribute-list route-policy DENY_DEFAULT in
  redistribute bgp 65510
  address-family ipv4 unicast
  area 0.0.0.0
   interface GigabitEthernet0/4/1/10
   !
   interface GigabitEthernet0/5/0/8
   !
   interface GigabitEthernet0/5/0/11
    network point-to-point
    dead-interval 40
    retransmit-interval 5
    hello-interval 10
    transmit-delay 1
   !
  !
 !
!
router ospf MN-SMART-INTERNET
 vrf MN-SMART-INTERNET
  distribute-list route-policy DENY_DEFAULT in
  default-information originate always
  address-family ipv4 unicast
  area 0
   interface TenGigE0/0/0/3
   !
  !
 !
!
router ospf MOBINET-L2-SERVICE
 vrf MOBINET-L2-SERVICE
  distribute-list route-policy DENY_DEFAULT in
  redistribute bgp 65510 route-policy HBB-PROVISION
  address-family ipv4 unicast
  area 0
   interface GigabitEthernet0/4/1/7
   !
  !
 !

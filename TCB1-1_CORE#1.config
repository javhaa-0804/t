!<oam>
privilege show all level 7 show
!</oam>
!<alarm>
alarm netconf-report notifications
logging file default almlog
  accept on
$
logging file default cmdlog
  buffer 1000
$
logging file default netclog
  accept on
$
logging file default snmplog
  accept on
$
logging file default srvlog
  accept on
  interval 10
$
logging file default weblog
  accept on
$
logging trap-enable notifications
logging snmp
  accept on
  match cmdlog
$
syslog level warnings
syslog-server host 192.168.242.11 alarmlog cmdlog debugmsg servicelog braslog na
tlog urllog nat-translationlog nat-portrangelog netconflog haglog snmplog weblog
syslog-server source interface loopback1
!</alarm>
!<ftp>
ftp-server enable
ftp-server top-directory /datadisk0/ read-write copy
ftp-client source-interface loopback1
!</ftp>
